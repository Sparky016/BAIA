{
  "name": "baia-server",
  "version": "0.0.0",
  "description": "NestJS backend orchestrator for BAIA",
  "private": true,
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint \"src/**/*.ts\"",
    "format:check": "prettier --check src"
  },
  "dependencies": {
    "@baia/shared": "*",
    "@github/copilot-sdk": "^1.0.2",
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^3.1.1",
    "@nestjs/core": "^10.3.0",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/swagger": "^7.4.2",
    "@octokit/rest": "^22.0.1",
    "adm-zip": "^0.5.17",
    "class-validator": "^0.14.0",
    "dotenv": "^16.3.1",
    "playwright": "^1.61.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.0",
    "@nestjs/testing": "^10.3.0",
    "@types/adm-zip": "^0.5.8",
    "@types/jest": "^29.5.8",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^6.13.1",
    "@typescript-eslint/parser": "^6.13.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.3.2"
  }
}
