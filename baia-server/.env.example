PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:4200

# LLM provider — use one of the two sections below.
#
# Option A: GitHub Copilot (default)
# Fill COPILOT_TOKEN; BYOK section is ignored.
COPILOT_TOKEN=
COPILOT_MODEL=gpt-4o
COPILOT_MAX_RETRIES=3
COPILOT_RETRY_DELAY_MS=500

# Option B: Bring Your Own Key (BYOK)
# Used automatically when COPILOT_TOKEN is blank.
# BYOK_PROVIDER_TYPE must be one of: openai | azure | anthropic
# BYOK_WIRE_API is optional (completions | responses); defaults to completions
# BYOK_AZURE_API_VERSION is optional; only used when BYOK_PROVIDER_TYPE=azure
BYOK_PROVIDER_TYPE=
BYOK_BASE_URL=
BYOK_API_KEY=
BYOK_MODEL=
BYOK_WIRE_API=
BYOK_AZURE_API_VERSION=

# Credential store — required; any long random string works
CREDENTIAL_ENCRYPTION_KEY=

# Repository to analyse during Phase 2 (optional — omit to skip code analysis)
REPO_URL=
REPO_PROVIDER=github
REPO_ACCESS_TOKEN=
