{
  "name": "baia",
  "version": "0.0.0",
  "description": "Business Analyst AI - autonomous agent for UI behaviour capture and business rule extraction",
  "private": true,
  "workspaces": [
    "baia-shared",
    "baia-ui",
    "baia-server",
    "e2e"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspace=@baia/shared --workspace=baia-ui --workspace=baia-server",
    "test:e2e": "npm run test --workspace=e2e",
    "coverage:aggregate": "node scripts/aggregate-coverage.mjs",
    "verify": "npm run lint && npm run build && npm run test && npm run coverage:aggregate && npm run test:e2e"
  },
  "devDependencies": {
    "@angular-eslint/eslint-plugin": "^22.0.0",
    "@angular-eslint/eslint-plugin-template": "^22.0.0",
    "@angular/compiler": "^19.2.0",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.6",
    "prettier": "^3.8.4"
  }
}
