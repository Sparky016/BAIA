@model IEnumerable<MyCMS.Models.ContentPage>
@{
    ViewBag.Title = "Admin Dashboard";
}

<div class="card">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
        <div>
            <h1 style="color: #fff; font-size: 2rem;">CMS Dashboard</h1>
            <p style="color: var(--text-muted);">Manage your site's dynamic pages and content.</p>
        </div>
        <a href="/Admin/Create" class="btn btn-primary">+ Create New Page</a>
    </div>

    <div class="table-responsive">
        <table>
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Title</th>
                    <th>Slug</th>
                    <th>Status</th>
                    <th>Last Updated</th>
                    <th style="text-align: right;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var page in Model)
                {
                    <tr>
                        <td>@page.Id</td>
                        <td style="font-weight: 600; color: #fff;">@page.Title</td>
                        <td><code>/@page.Slug</code></td>
                        <td>
                            @if (page.IsPublished)
                            {
                                <span class="badge badge-success">Published</span>
                            }
                            else
                            {
                                <span class="badge badge-warning">Draft</span>
                            }
                        </td>
                        <td>@page.UpdatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                        <td style="text-align: right; display: flex; justify-content: flex-end; gap: 0.5rem; align-items: center;">
                            <a href="/@page.Slug" target="_blank" class="btn btn-outline" style="padding: 0.4rem 0.8rem; font-size: 0.875rem;">View</a>
                            <a href="/Admin/Edit/@page.Id" class="btn btn-secondary" style="padding: 0.4rem 0.8rem; font-size: 0.875rem;">Edit</a>
                            
                            @using (Html.BeginForm("Delete", "Admin", new { id = page.Id }, FormMethod.Post, new { style = "display:inline; margin:0;" }))
                            {
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-danger" style="padding: 0.4rem 0.8rem; font-size: 0.875rem;" onclick="return confirm('Are you sure you want to delete this page?');">Delete</button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
