@model MyCMS.Models.ContentPage
@{
    ViewBag.Title = Model.Title;
}

<article class="card">
    <header style="margin-bottom: 2rem; border-bottom: 1px solid var(--border-color); padding-bottom: 1rem;">
        <h1 style="font-size: 2.5rem; color: #fff; margin-bottom: 0.5rem;">@Model.Title</h1>
        <div style="font-size: 0.875rem; color: var(--text-muted); display: flex; gap: 1rem;">
            <span>Created: @Model.CreatedAt.ToString("yyyy-MM-dd HH:mm")</span>
            @if (Model.UpdatedAt != Model.CreatedAt)
            {
                <span>Updated: @Model.UpdatedAt.ToString("yyyy-MM-dd HH:mm")</span>
            }
        </div>
    </header>

    <div class="content-body" style="font-size: 1.125rem; color: var(--text-color);">
        @Html.Raw(Model.Content)
    </div>
</article>
